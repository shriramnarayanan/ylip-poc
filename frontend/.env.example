# LM Studio
YLIP_LM_STUDIO_BASE_URL=http://localhost:1234/v1
YLIP_LM_STUDIO_MODEL=google/gemma-3-4b

# Vision - moondream2 via LM Studio
YLIP_VISION_MODEL=moondream2
YLIP_VISION_ENABLED=true

# TTS - Kokoro backend (backend/tts/main.py)
YLIP_TTS_BASE_URL=http://localhost:8880/v1
YLIP_TTS_MODEL=kokoro
YLIP_TTS_ENABLED=true

# STT
YLIP_STT_BASE_URL=http://localhost:8881/v1
YLIP_STT_ENABLED=true

# Image generation - Stable Diffusion
YLIP_IMAGE_BASE_URL=http://localhost:8882/v1
YLIP_IMAGE_ENABLED=true

# Code execution - matplotlib plots (backend/code_exec/main.py)
YLIP_CODE_EXEC_BASE_URL=http://localhost:8883/v1
YLIP_CODE_EXEC_ENABLED=true

# Music generation - MusicGen (backend/music/main.py)
YLIP_MUSIC_GEN_BASE_URL=http://localhost:8884/v1
YLIP_MUSIC_GEN_ENABLED=true
