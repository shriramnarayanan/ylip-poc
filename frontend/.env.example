# LM Studio
YLIP_LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
YLIP_LM_STUDIO_MODEL=google/gemma-3-4b

# Vision - moondream2 via LM Studio
YLIP_VISION_MODEL=moondream2
YLIP_VISION_ENABLED=true

# TTS - Kokoro backend (backend/tts/main.py)
YLIP_TTS_BASE_URL=http://host.docker.internal:8880/v1
YLIP_TTS_MODEL=kokoro
YLIP_TTS_ENABLED=true

# STT
YLIP_STT_BASE_URL=http://host.docker.internal:8881/v1
YLIP_STT_ENABLED=true

# Image generation - Stable Diffusion
YLIP_IMAGE_BASE_URL=http://host.docker.internal:8882/v1
YLIP_IMAGE_ENABLED=true

# Code execution - matplotlib plots (backend/code_exec/main.py)
YLIP_CODE_EXEC_BASE_URL=http://host.docker.internal:8883/v1
YLIP_CODE_EXEC_ENABLED=true

# Music generation - MusicGen (backend/music/main.py)
YLIP_MUSIC_GEN_BASE_URL=http://host.docker.internal:8884/v1
YLIP_MUSIC_GEN_ENABLED=true

# MCP subject-matter server (mcp-subject-matter service)
YLIP_MCP_SUBJECT_MATTER_URL=http://mcp-subject-matter:8770/sse

# Student state management (student-history service)
YLIP_STUDENT_STATE_BASE_URL=http://student-history:8771
YLIP_STUDENT_STATE_ENABLED=true
